rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }
    match /acknowledgements/{ackId} {
      allow read, write: if true;
    }
    match /briefings/{briefingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /dayMarks/{markId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /directoryEdits/{editId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /customJobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /jobPatches/{patchId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /toolboxDocs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
